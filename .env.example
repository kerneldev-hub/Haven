# ==============================================================================
#                      HAVEN OS - ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 🚀 SYSTEM CORE CONFIGURATION
# ------------------------------------------------------------------------------
# Node runtime environment (development or production)
NODE_ENV=development
# The public/ingress URL of the application (e.g. https://haven-os-run.aistudio.google)
APP_URL=http://localhost:3000
# JWT token signing secret for secure session control
JWT_SECRET=dev-secret-change-in-production-long-secure-string

# ------------------------------------------------------------------------------
# 🧠 GEMINI AI CAPABILITIES
# ------------------------------------------------------------------------------
# Required for Gemini AI API calls (injected automatically in AI Studio UI)
GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# 🗄️ TURSO DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Turso Database libsql connection URL (e.g., libsql://your-db-tenant.turso.io)
# Fallback: file:local.db (embedded SQLite)
DATABASE_URL=libsql://your-db-tenant.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token-jwt

# ------------------------------------------------------------------------------
# 🔐 LOGTO AUTHENTICATION SYSTEM (OAUTH2 Central SSO)
# ------------------------------------------------------------------------------
# Central Logto console tenant URL
LOGTO_ENDPOINT=https://your-tenant.logto.app
# Logto Application Identity ID
LOGTO_APP_ID=your-logto-app-id
# Logto Application Private Client Secret
LOGTO_APP_SECRET=your-logto-app-secret
# Secure long cookie-signer secret key (minimum 32-characters)
LOGTO_COOKIE_SECRET=a-very-long-and-secure-cookie-secret-32-chars

# ------------------------------------------------------------------------------
# 📡 ABLY REAL-TIME & WEBRTC SIGNALING
# ------------------------------------------------------------------------------
# Ably application private API key
ABLY_API_KEY=your-ably-api-key

# ------------------------------------------------------------------------------
# 💳 PAYMENT GATEWAY INTEGRATIONS
# ------------------------------------------------------------------------------
# Chargily Pay V2 Private API Key (starts with api_sk_)
CHARGILY_SECRET_KEY=api_sk_test_...
# Chargily Webhook Signature HMAC Validator Key
CHARGILY_WEBHOOK_SECRET=your-chargily-webhook-secret

# BTCPay Server Merchant / Store API Token
BTCPAY_SERVER_API_KEY=your-btcpay-api-key
BTCPAY_SERVER_STORE_ID=your-btcpay-store-id

# ------------------------------------------------------------------------------
# 📲 NOTIFICATIONS & RELEASE PLATFORMS
# ------------------------------------------------------------------------------
# Firebase Cloud Messaging Service Account (Base64 Encoded JSON)
FCM_SERVICE_ACCOUNT=your-base64-fcm-json
# GitHub personal access token for fetching releases/tag info
GITHUB_TOKEN=ghp_...
