{
  "productName": "Haven",
  "version": "0.1.0",
  "identifier": "com.haven.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Haven",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.turso.tech wss://*.turso.tech https://your-coolify-domain.com; img-src 'self' data: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "appimage", "deb"],
    "identifier": "com.haven.app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
